# =============================================================================
# Wiki.js - Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# =============================================================================

# -----------------------------------------------------------------------------
# Wiki.js - Required
# -----------------------------------------------------------------------------

# Generate with: echo "WIKIJS_PG_PASS=$(openssl rand -base64 36 | tr -d '\n')" >> .env
WIKIJS_PG_PASS=

# -----------------------------------------------------------------------------
# Wiki.js - Optional (defaults shown)
# -----------------------------------------------------------------------------
WIKIJS_PG_USER=wikijs
WIKIJS_PG_DB=wiki
