# Termix Testing Environment
# Copy this file to .env and fill in the values below before starting.

# ─── Security ─────────────────────────────────────────────────────────────────

# Encryption salt (max 32 characters, mix uppercase/lowercase/numbers/special chars)
# Generate: openssl rand -base64 24
TERMIX_SALT=replace_me

# ─── Application ──────────────────────────────────────────────────────────────

# Internal port Termix listens on (default 8080, rarely needs changing)
TERMIX_PORT=8080
