# Puppet Testing Environment Variables
# Copy this file to .env and fill in the values before starting the stack.

# ─── PostgreSQL (required) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=

# ─── Puppetboard (required) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
PUPPETBOARD_SECRET_KEY=

# ─── PostgreSQL (optional — defaults shown) ────────────────────────────────────
POSTGRES_DB=puppetdb
POSTGRES_USER=puppetdb

# ─── JVM Tuning (optional — defaults shown) ───────────────────────────────────
# Puppet Server needs ~512MB minimum; PuppetDB needs ~256MB minimum
PUPPETSERVER_JAVA_ARGS=-Xms512m -Xmx512m
PUPPETDB_JAVA_ARGS=-Xms256m -Xmx256m
