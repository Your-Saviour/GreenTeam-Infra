# DFIR-IRIS Testing Environment
# Copy this file to .env and fill in the values below before starting.

# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL credentials
# Generate password: openssl rand -base64 32
POSTGRES_DB=iris_db
POSTGRES_USER=iris
POSTGRES_PASSWORD=replace_me

# ─── Application ─────────────────────────────────────────────────────────────

# Flask secret key for session signing
# Generate: openssl rand -base64 32
IRIS_SECRET_KEY=replace_me

# Password salt for hashing
# Generate: openssl rand -base64 32
IRIS_SECURITY_PASSWORD_SALT=replace_me

# Initial admin account password (set on first boot only)
# Must be at least 12 characters with uppercase, lowercase, digit, and special char
IRIS_ADM_PASSWORD=replace_me

# Admin account details (optional, defaults shown)
# IRIS_ADM_EMAIL=admin@localhost
# IRIS_ADM_USERNAME=administrator
