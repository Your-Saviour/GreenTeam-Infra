# Elastic Stack 8.17 Testing Environment Variables
# Copy this file to .env and fill in the values before starting the stack.

# ─── Stack Version ──────────────────────────────────────────────────────────
STACK_VERSION=9.3.2

# ─── Elasticsearch ──────────────────────────────────────────────────────────
# Password for the built-in 'elastic' superuser.
# Generate with: openssl rand -base64 24
ELASTIC_PASSWORD=

# Password for the 'kibana_system' built-in user (Kibana → ES auth).
# Generate with: openssl rand -base64 24
KIBANA_SYSTEM_PASSWORD=

# Cluster name used by all nodes.
CLUSTER_NAME=elastic-testing

# JVM heap size per Elasticsearch node (512m minimum for testing).
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ─── Kibana ─────────────────────────────────────────────────────────────────
# Encryption keys (required for Fleet, alerting, reporting). Must be 32+ chars.
# Generate each with: openssl rand -hex 16
KIBANA_ENCRYPTION_KEY=
KIBANA_SECURITY_KEY=
KIBANA_REPORTING_KEY=

# ─── Logstash ───────────────────────────────────────────────────────────────
# Logstash JVM heap size.
LS_JAVA_OPTS=-Xms256m -Xmx256m
