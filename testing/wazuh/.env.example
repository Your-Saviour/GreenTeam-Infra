# Wazuh Testing Stack Environment Variables
# Copy this file to .env and fill in the values before starting the stack.

# ─── Wazuh Indexer (OpenSearch) ───────────────────────────────────────────────
# Admin password for the Wazuh indexer. Used for dashboard login and API access.
# This must match the indexer's internal_users.yml. Default is 'admin'.
INDEXER_PASSWORD=admin

# ─── Wazuh API ────────────────────────────────────────────────────────────────
# Credentials for dashboard → manager API communication.
API_USERNAME=wazuh-wui
API_PASSWORD=MyS3cr37P450r.*-

# ─── Wazuh Dashboard ─────────────────────────────────────────────────────────
# Internal kibanaserver user password.
DASHBOARD_PASSWORD=kibanaserver
