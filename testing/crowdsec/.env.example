# CrowdSec Testing Environment
# Copy this file to .env and fill in the values below before starting.

# --- CrowdSec Bouncer ---

# API key shared between CrowdSec LAPI and the Traefik bouncer plugin.
# Must be the same value in both places. The CrowdSec container auto-registers
# the bouncer on first start using this key.
# Generate: openssl rand -base64 32
CROWDSEC_BOUNCER_KEY=replace_me

# --- Grafana ---

# Admin password for the Grafana dashboard at crowdsec.testing.blueteam.au
# Generate: openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=replace_me

# --- PostgreSQL (Grafana backend) ---

# Grafana's own database. Not used by CrowdSec itself.
# Generate password: openssl rand -base64 32
POSTGRES_DB=grafana
POSTGRES_USER=grafana
POSTGRES_PASSWORD=replace_me
