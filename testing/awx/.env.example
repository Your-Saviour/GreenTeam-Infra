# AWX Testing Stack Environment Variables
# Copy this file to .env and fill in the values before starting the stack.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Credentials for the AWX database. Change before first start.
PG_DATABASE=awx
PG_USER=awx
PG_PASSWORD=changeme_strong_pg_password

# ─── AWX Admin ───────────────────────────────────────────────────────────────
# Initial superuser credentials for the AWX web UI.
AWX_ADMIN_USER=admin
AWX_ADMIN_PASSWORD=changeme_strong_admin_password

# ─── AWX Secret Key ─────────────────────────────────────────────────────────
# Used for encrypting secrets in the database. Must be identical on web and task.
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
