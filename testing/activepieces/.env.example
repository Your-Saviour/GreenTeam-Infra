# Activepieces Testing Environment Variables
# Copy this file to .env and fill in the values before starting the stack.

# ─── Security (required) ───────────────────────────────────────────────────────
# 256-bit encryption key — must be exactly 32 hex characters.
# Generate with: openssl rand -hex 16
AP_ENCRYPTION_KEY=

# JWT signing secret.
# Generate with: openssl rand -base64 32
AP_JWT_SECRET=

# ─── PostgreSQL (required) ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
AP_POSTGRES_PASSWORD=

# ─── PostgreSQL (optional — defaults shown) ────────────────────────────────────
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=postgres
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME=postgres

# ─── Redis (optional — defaults shown) ─────────────────────────────────────────
AP_REDIS_HOST=redis
AP_REDIS_PORT=6379

# ─── Application ───────────────────────────────────────────────────────────────
AP_ENVIRONMENT=prod
AP_EXECUTION_MODE=UNSANDBOXED
AP_TELEMETRY_ENABLED=false
AP_ENGINE_EXECUTABLE_PATH=dist/packages/engine/main.js

# ─── Tuning (optional — defaults shown) ────────────────────────────────────────
# AP_WEBHOOK_TIMEOUT_SECONDS=30
# AP_TRIGGER_DEFAULT_POLL_INTERVAL=5
# AP_FLOW_TIMEOUT_SECONDS=600
