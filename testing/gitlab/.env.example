# GitLab CE Testing Environment Variables
# Copy this file to .env and fill in the values before starting the stack.

# ─── GitLab (required) ────────────────────────────────────────────────────────
# Initial root password — must be at least 8 characters.
# This is only used on the very first start; changing it later has no effect.
# Generate with: openssl rand -base64 24
GITLAB_ROOT_PASSWORD=

# ─── PostgreSQL (required) ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 24
GITLAB_DB_PASSWORD=

# ─── PostgreSQL (optional — defaults shown) ───────────────────────────────────
# GITLAB_DB_NAME=gitlabhq_production
# GITLAB_DB_USER=gitlab

# ─── Runner Registration ──────────────────────────────────────────────────────
# After GitLab is running, register the runner manually:
#
#   1. Log in to https://gitlab.testing.blueteam.au as root
#   2. Go to Admin Area > CI/CD > Runners > New instance runner
#   3. Copy the runner authentication token (starts with glrt-), then run:
#
#      docker exec -it gitlab-runner gitlab-runner register \
#        --non-interactive \
#        --url http://gitlab:80 \
#        --clone-url http://gitlab:80 \
#        --token <RUNNER_TOKEN> \
#        --executor docker \
#        --docker-image alpine:latest
#
# Note: The runner itself uses the internal HTTP URL (not the public HTTPS URL)
# because it communicates directly with GitLab on the gitlab-internal network.
# Job containers run on Docker's default bridge network so they have internet
# access (for pulling images, apt-get, etc.). If your jobs need to reach GitLab
# directly, use the public URL (https://gitlab.testing.blueteam.au) in CI scripts.
