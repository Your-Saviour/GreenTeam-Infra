# =============================================================================
# authentik + Homarr - Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# =============================================================================

# -----------------------------------------------------------------------------
# authentik - Required
# -----------------------------------------------------------------------------

# Generate with: echo "PG_PASS=$(openssl rand -base64 36 | tr -d '\n')" >> .env
PG_PASS=

# Generate with: echo "AUTHENTIK_SECRET_KEY=$(openssl rand -base64 60 | tr -d '\n')" >> .env
AUTHENTIK_SECRET_KEY=

# -----------------------------------------------------------------------------
# authentik - Optional (defaults shown)
# -----------------------------------------------------------------------------
PG_USER=authentik
PG_DB=authentik

# -----------------------------------------------------------------------------
# authentik - Email (recommended for MFA recovery and password resets)
# -----------------------------------------------------------------------------
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USERNAME=authentik@example.com
# EMAIL_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_FROM=authentik@example.com

# -----------------------------------------------------------------------------
# Homarr - Required
# -----------------------------------------------------------------------------

# Generate with: echo "HOMARR_ENCRYPTION_KEY=$(openssl rand -hex 32)" >> .env
HOMARR_ENCRYPTION_KEY=

# Fill these in after creating the Homarr OIDC app in authentik:
# The slug is the "Application Slug" shown in authentik's application settings
HOMARR_OIDC_CLIENT_ID=
HOMARR_OIDC_CLIENT_SECRET=
HOMARR_OIDC_SLUG=homarr

# -----------------------------------------------------------------------------
# Homarr - Optional (defaults shown)
# -----------------------------------------------------------------------------
TZ=Australia/Adelaide

# -----------------------------------------------------------------------------
# Vaultwarden - OIDC (fill in after creating the Vaultwarden app in authentik)
# -----------------------------------------------------------------------------
VAULTWARDEN_OIDC_CLIENT_ID=
VAULTWARDEN_OIDC_CLIENT_SECRET=
VAULTWARDEN_OIDC_SLUG=vaultwarden
